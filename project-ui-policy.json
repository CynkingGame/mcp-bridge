{
  "project": "BigWinGame",
  "canvas": {
    "designResolution": {
      "width": 720,
      "height": 1280
    },
    "fitWidth": true,
    "fitHeight": false
  },
  "createNode": {
    "autoParentUiToCanvas": true,
    "defaultPresetsByType": {
      "button": "button"
    }
  },
  "prefabRoot": {
    "autoDetectScreenRoot": {
      "enabled": true,
      "preset": "screen-root",
      "tolerance": 4
    }
  },
  "presets": {
    "button": {
      "anchor": {
        "x": 0.5,
        "y": 0.5
      },
      "description": "Buttons use a center anchor by default so scale transitions stay visually stable."
    },
    "screen-root": {
      "anchor": {
        "x": 0.5,
        "y": 0.5
      },
      "layout": "full",
      "description": "Full-screen prefab root that stretches with long screens."
    },
    "safe-area-root": {
      "anchor": {
        "x": 0.5,
        "y": 0.5
      },
      "layout": "full",
      "safeArea": true,
      "description": "Top-level interactive root constrained to the device safe area."
    }
  }
}
